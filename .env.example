# ============================================================
# REQUIRED — must be set for any environment
# ============================================================

# Payload CMS secret. Generate: openssl rand -base64 32
PAYLOAD_SECRET=""

# Database connection. Format depends on starter.config.ts → database.provider:
#   postgres: postgres://user:pass@host:5432/dbname
#   sqlite:   file:./local.db
DATABASE_URL="mongodb://127.0.0.1:27017/payload-starter"

# Public URL of the site (no trailing slash)
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

# ============================================================
# STORAGE — required only if storage.provider !== 'local'
# ============================================================

# === S3 (provider='s3') ===
# S3_BUCKET=""
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""                # optional, for R2/MinIO

# === GCS (provider='gcs') ===
# GCS_BUCKET=""
# GOOGLE_APPLICATION_CREDENTIALS="./gcs-key.json"

# === Vercel Blob (provider='vercel-blob') ===
# BLOB_READ_WRITE_TOKEN=""

# ============================================================
# CDN — optional, sets public URL prefix for media
# ============================================================
# NEXT_PUBLIC_CDN_URL=""

# ============================================================
# EMAIL — required only if email.provider !== 'console'
# ============================================================

# === Resend (provider='resend') ===
# RESEND_API_KEY=""

# === SMTP (provider='smtp') ===
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""

# === SendGrid (provider='sendgrid') ===
# SENDGRID_API_KEY=""

# ============================================================
# OPTIONAL
# ============================================================

# Live preview secret (for draft preview from Payload admin)
PREVIEW_SECRET=""

# ============================================================
# SEO — optional (sensible defaults in src/utilities/siteConfig.ts)
# ============================================================

# Site identity used in metadata / Open Graph / structured data
# NEXT_PUBLIC_SITE_NAME="My Blog"
# NEXT_PUBLIC_SITE_DESCRIPTION="A blog built with Payload CMS and Next.js."
# NEXT_PUBLIC_OG_LOCALE="en_US"
# NEXT_PUBLIC_TWITTER_HANDLE="@handle"
# NEXT_PUBLIC_DEFAULT_OG_IMAGE="/og-default.png"

# Force noindex (staging/preview). "1" => robots.txt Disallow: /
# ROBOTS_NOINDEX="0"

# On-demand cache revalidation webhook (POST /api/revalidate)
# REVALIDATE_SECRET=""

# IndexNow key (Bing/Yandex/Naver). Served at /indexnow.txt; production-only.
# INDEXNOW_KEY=""

# Node environment
NODE_ENV="development"
