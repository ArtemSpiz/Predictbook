# ============================================================
# REQUIRED — must be set for any environment
# ============================================================

# Payload CMS secret. Generate: openssl rand -base64 32
PAYLOAD_SECRET=""

# Database connection (MongoDB in this project). Get it from MongoDB Atlas:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Never commit a real connection string — it belongs only in the private .env.
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/payload-portal?retryWrites=true&w=majority"

# MongoDB connection pool (serverless-safe defaults). Keep MONGO_MAX_POOL_SIZE small:
# per-instance pool × max concurrency must stay under the Atlas connection cap.
# MONGO_MAX_POOL_SIZE="10"
# MONGO_MIN_POOL_SIZE="0"
# MONGO_SERVER_SELECTION_TIMEOUT_MS="5000"
# MONGO_SOCKET_TIMEOUT_MS="45000"

# Public URL of the site (no trailing slash). Production: https://your-domain.com
NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

# ============================================================
# STORAGE — pick the provider (local for dev, s3 for production/R2)
# ============================================================

# Storage backend: local (default) | s3 | gcs | vercel-blob
# STORAGE_PROVIDER="s3"

# === S3 / Cloudflare R2 (STORAGE_PROVIDER=s3) ===
# For Cloudflare R2 use these exact settings (R2 is S3-compatible):
#   S3_REGION=auto
#   S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# For real AWS S3, set S3_REGION to the bucket region and omit S3_ENDPOINT.
# S3_BUCKET=""
# S3_REGION="auto"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""

# === GCS (STORAGE_PROVIDER=gcs) ===
# GCS_BUCKET=""
# GOOGLE_APPLICATION_CREDENTIALS="./gcs-key.json"

# === Vercel Blob (STORAGE_PROVIDER=vercel-blob) ===
# BLOB_READ_WRITE_TOKEN=""

# ============================================================
# CDN — public URL prefix for media (serves images directly, bypassing the app).
# For R2: the bucket's public r2.dev URL or a custom domain (e.g. media.your-domain.com).
# When set alongside STORAGE_PROVIDER=s3, media is served straight from this URL.
# ============================================================
# NEXT_PUBLIC_CDN_URL=""

# Extra hosts allowed for Next Image Optimization (comma-separated bare hosts or
# URLs), in addition to NEXT_PUBLIC_CDN_URL / NEXT_PUBLIC_SERVER_URL. Example:
# NEXT_PUBLIC_IMAGE_HOSTS="bucket.r2.dev,logos.example.com"

# ============================================================
# EMAIL — required only if EMAIL_PROVIDER !== 'console'
# ============================================================

# Provider: console (default, logs only) | resend | smtp | sendgrid
# EMAIL_PROVIDER="console"
# Verified sender address mail is sent "from"
# EMAIL_FROM="noreply@predictbook.co"

# === Resend (provider='resend') ===
# RESEND_API_KEY=""

# === SMTP (provider='smtp') ===
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""

# === SendGrid (provider='sendgrid') ===
# SENDGRID_API_KEY=""

# Contact form fallback recipient — used when a subject has no routeTo and the
# Contact Page has no default recipient set in the CMS.
# CONTACT_INBOX=""

# ============================================================
# OPTIONAL
# ============================================================

# Live preview secret (for draft preview from Payload admin)
PREVIEW_SECRET=""

# ============================================================
# SEO — optional (sensible defaults in src/utilities/siteConfig.ts)
# ============================================================

# Site identity used in metadata / Open Graph / structured data
# NEXT_PUBLIC_SITE_NAME="Predictbook"
# NEXT_PUBLIC_SITE_DESCRIPTION="A news site built with Payload CMS and Next.js."

# ============================================================
# CAPTCHA — Cloudflare Turnstile on the contact form (optional).
# Create a widget at Cloudflare dashboard → Turnstile. When both are set the
# contact form requires a captcha; unset = form works without it.
# ============================================================
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""   # build-time (inlined into the client)
# TURNSTILE_SECRET_KEY=""             # runtime (server verification)
# NEXT_PUBLIC_OG_LOCALE="en_US"
# NEXT_PUBLIC_TWITTER_HANDLE="@handle"
# NEXT_PUBLIC_DEFAULT_OG_IMAGE="/og-default.png"

# Force noindex (staging/preview). "1" => robots.txt Disallow: /
# ROBOTS_NOINDEX="0"

# On-demand cache revalidation webhook (POST /api/revalidate)
# REVALIDATE_SECRET=""

# ============================================================
# SIGNALS SYNC — ingest whale/arbitrage signals from the external Signals API.
# The poller runs inside the app (single-instance deploys only) and upserts
# into the `signals` collection. Upstream is HTTP-only; fetched server-side.
# Production defaults ship in docker-compose.prod.yml — set these only to
# override them (or to enable the poller in local dev).
# ============================================================
# SIGNALS_SYNC_ENABLED="true"
# SIGNALS_API_URL="http://5.78.144.147:8790/api/signals"
# SIGNALS_SYNC_INTERVAL_MS="1800000"
# SIGNALS_SYNC_BATCH_LIMIT="50"
# Secret for the internal /api/signals-sync tick route. Optional: when unset,
# the app generates one per boot (poller and route share the same process).
# SIGNALS_SYNC_SECRET=""
# Retention: prune synced, non-featured signals older than N days and beyond
# the newest N docs (whichever hits first). 0 disables that rule.
# SIGNALS_RETENTION_DAYS="30"
# SIGNALS_RETENTION_LIMIT="1000"

# ============================================================
# TICKER SYNC — fill the header ticker with top-volume markets fetched
# directly from the Polymarket and Kalshi public APIs. The poller runs inside
# the app (single-instance deploys only) and reconciles the `ticker`
# collection; manually created rows are never touched. Production defaults
# ship in docker-compose.prod.yml — set these only to override them (or to
# enable the poller in local dev). Shares SIGNALS_SYNC_SECRET.
# ============================================================
# TICKER_SYNC_ENABLED="true"
# TICKER_SYNC_INTERVAL_MS="300000"
# TICKER_SYNC_LIMIT_PER_VENUE="10"
# KALSHI_SYNC_MAX_PAGES="10"
# POLYMARKET_GAMMA_URL="https://gamma-api.polymarket.com/markets"
# KALSHI_API_URL="https://api.elections.kalshi.com/trade-api/v2/markets"

# IndexNow key (Bing/Yandex/Naver). Served at /indexnow.txt; production-only.
# INDEXNOW_KEY=""

# Node environment
NODE_ENV="development"
